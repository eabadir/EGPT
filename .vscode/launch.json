{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node Run Current (Console Input)",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Node Run Debug (Debug Console)",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "internalConsole",
      "runtimeVersion": "22"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "RAG Sync Server",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/rag-sync/src/server/express-server.js",
      "cwd": "${workspaceFolder}/rag-sync",
      "env": {
        "NODE_ENV": "development",
        "PORT": "3000",
        "LOG_LEVEL": "debug",
        "GOOGLE_CLOUD_PROJECT": "descix",
        "GOOGLE_CLOUD_REGION": "us-central1"
      },
      "envFile": "${workspaceFolder}/rag-sync/config/.env",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "RAG Sync CLI",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/rag-sync/src/cli/index.js",
      "cwd": "${workspaceFolder}/rag-sync",
      "args": [
        "${input:cliCommand}"
      ],
      "env": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug"
      },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Address Is The Map Visualizer",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/web/the-address-is-the-map-visualizer/node_modules/.bin/vite",
      "cwd": "${workspaceFolder}/web/the-address-is-the-map-visualizer",
      "args": [
        "--host",
        "0.0.0.0",
        "--port",
        "3000"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "outputCapture": "std",
      "autoAttachChildProcesses": true,
      "presentation": {
        "group": "web-apps",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Address Is The Map Visualizer (Build)",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/web/the-address-is-the-map-visualizer/node_modules/.bin/vite",
      "cwd": "${workspaceFolder}/web/the-address-is-the-map-visualizer",
      "args": [
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      },
      "console": "integratedTerminal",
      "outputCapture": "std",
      "presentation": {
        "group": "web-apps",
        "order": 2
      }
    }
  ],
  "inputs": [
    {
      "id": "cliCommand",
      "type": "pickString",
      "description": "Select CLI command",
      "options": [
        "init",
        "sync",
        "sync --dry-run",
        "sync --full",
        "status",
        "query 'test question'"
      ],
      "default": "status"
    }
  ]
}